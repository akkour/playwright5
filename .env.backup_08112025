# ===========================================
# EvaRAG Crawler Service v3.2 Configuration
# ===========================================

# ✅ FEATURE TOGGLES - Phase 1 Deployment Control
# Permet déploiement progressif SANS risque de régression
ENABLE_CRAWLER_V2=false              # true = Active améliorations v3.2 | false = Version originale
ENABLE_ADAPTIVE_TIMEOUTS=true        # true = Timeouts adaptatifs | false = Timeout fixe
ENABLE_ADVANCED_LOGGING=true         # true = Logs détaillés | false = Logs basiques

# ===========================================
# TIMEOUTS CONFIGURATION v3.2
# ===========================================
# ✅ Timeouts optimisés (réduits pour performance)
DEFAULT_NAV_TIMEOUT=30000            # 30s (réduit de 60s) - Timeout navigation standard
FAST_TIMEOUT=15000                   # 15s - Pages rapides/statiques  
SLOW_TIMEOUT=45000                   # 45s - Pages lentes (vidéos, admin dashboards)

# ===========================================
# BFS ALGORITHM CONFIGURATION v3.2  
# ===========================================
# ✅ Configuration BFS améliorée
BFS_QUEUE_MULTIPLIER=3               # Multiplicateur taille queue (3 = plus permissif que 5)
BFS_SEEN_MULTIPLIER=2                # Multiplicateur taille seen (NOUVEAU - évite accumulation)
MAX_CONCURRENT_PAGES=3               # Préparation concurrence future

# ===========================================
# CORE SERVICE CONFIGURATION
# ===========================================
PORT=11235                           # Port du service
UVICORN_WORKERS=2                    # Nombre de workers Uvicorn

# Redis Cache (optionnel)
REDIS_URL=redis://localhost:6379     # URL Redis pour cache (optionnel)

# CORS Origins  
CORS_ALLOW_ORIGINS=*                 # Origins autorisées (* = tous)

# ===========================================
# EDGE FUNCTIONS INTEGRATION
# ===========================================
# Secrets partagés avec Edge Functions
CRAWLER_WORKER_SECRET=crawler_worker_7f3fca91f20e4f7c8b7c9e5f1f3a2e89     # Secret pour auth Edge Functions
CRAWLER_CALLBACK_URL=                         # URL callback par défaut (optionnel)
CRAWLER_SYNC_URL=https://puppeteer.evaleads.com/crawl4ai/crawl
CRAWLER_ASYNC_URL=https://puppeteer.evaleads.com/crawl4ai/jobs
CRAWLER_HEALTH_URL=https://puppeteer.evaleads.com/crawl4ai/health
DOC_PROCESSOR_SECRET=doc_processor_secret_b5e8d1a9f0c34a2e9b8d4e7f2c1b3a5d
N8N_TRIAGE_URL=https://n8n.evaleads.com/webhook/triage-doc-complexity-webhook
N8N_LLM_OCR_URL=https://n8n.evaleads.com/webhook/llm-ocr-engine
# Interrupteur pour le moteur OCR complexe : 'llm' ou 'google'
#COMPLEX_OCR_ENGINE=llm
COMPLEX_OCR_ENGINE=google

# Alternative env vars (compatibilité)  
PUPPETEER_SERVICE_BASE=https://puppeteer.evaleads.com
CRAWLER_WORKER_URL=https://puppeteer.evaleads.com/jobs
CRAWLER_WORKER_BASE_URL=https://puppeteer.evaleads.com

# ===========================================
# MONITORING & LOGGING
# ===========================================
# Répertoires
LOG_DIR=logs                         # Répertoire logs
DATA_DIR=data                        # Répertoire exports

# Métriques Prometheus
METRICS_RETENTION=86400              # Rétention métriques (24h)
MONITORING_INTERVAL=5                # Intervalle monitoring (secondes)

# ===========================================
# PERFORMANCE & LIMITS
# ===========================================
# Limites ressources
MAX_LINKS_RETURNED=15                # Max liens retournés par page
CACHE_TTL=3600                       # TTL cache (1h)
STATIC_TIMEOUT=20                    # Timeout requêtes HTTP statiques (20s)

# ===========================================
# DEPLOYMENT STRATEGY v3.2
# ===========================================

# PHASE 1 - Tests initiaux (Recommandé)
# ENABLE_CRAWLER_V2=false
# ENABLE_ADAPTIVE_TIMEOUTS=true  
# ENABLE_ADVANCED_LOGGING=true

# PHASE 2 - Tests A/B (Après validation Phase 1) 
# ENABLE_CRAWLER_V2=true (sur 10% traffic)
# Surveillance métriques /health/detailed

# PHASE 3 - Déploiement progressif
# ENABLE_CRAWLER_V2=true (25% → 50% → 100%)

# ROLLBACK IMMÉDIAT (si problème)
# ENABLE_CRAWLER_V2=false + redémarrage service

# ===========================================
# VALIDATION & TESTING
# ===========================================

# Variables pour tests automatisés
TEST_BASE_URL=http://localhost:11235
TEST_SAMPLE_URL=https://example.com
TEST_MAX_PAGES=5
TEST_TIMEOUT=30

# Seuils de validation performance
MIN_PAGES_CRAWLED=1                  # Minimum pages crawlées (test régression)
MAX_RESPONSE_TIME=120                # Maximum temps réponse (secondes)
MIN_SUCCESS_RATE=0.8                 # Taux succès minimum (80%)

# ===========================================
# PRODUCTION RECOMMENDATIONS
# ===========================================

# Production optimisée:
# ENABLE_CRAWLER_V2=true
# ENABLE_ADAPTIVE_TIMEOUTS=true
# ENABLE_ADVANCED_LOGGING=false (performance)
# UVICORN_WORKERS=4
# REDIS_URL=redis://prod-redis:6379

