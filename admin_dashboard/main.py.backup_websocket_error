async def check_service_changes(services: List[Dict[str, Any]]):
    """Vérifier les changements d'état des services"""
    for service in services:
        name = service.get("name")
        state = service.get("state")
        
        if name in previous_service_states:
            previous_state = previous_service_states[name]
            
            # Détecter les changements critiques
            if previous_state == "running" and state in ["stopped", "exited"]:
                # Service vient de tomber !
                await send_email_alert(name, state, previous_state)
            elif previous_state in ["stopped", "exited"] and state == "running":
                # Service revenu (email de récupération optionnel)
                # await send_recovery_alert(name, state, previous_state)
                pass
        
        # Mémoriser l'état actuel
        previous_service_states[name] = state

